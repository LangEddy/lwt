# --- Local development with `supabase start` ---
# These are the values printed by `supabase status` after a fresh start.
# Copy this file to `backend/.env` and uncomment the local block.

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
PORT=3000

# --- Production / hosted Supabase ---
# Use the SESSION pooler (port 5432). The transaction pooler (6543) breaks
# sqlx prepared statements.
#
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_URL=https://<ref>.supabase.co
