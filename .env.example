# Backend
# Supabase Postgres connection string (server-side only)
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase JWT secret used by backend token validation middleware
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# API server port
PORT=3000

# Frontend (Vite)
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Preferred client key (new format)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Legacy fallback (only if you have not migrated keys yet)
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
