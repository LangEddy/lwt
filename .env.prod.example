# ─── Backend (server-side only, never exposed to browser) ───────────────────

# Supabase Postgres connection string
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase project URL (used by backend to fetch JWKS for JWT validation)
SUPABASE_URL=https://<project-ref>.supabase.co

# ─── Frontend (baked into the Vite build at docker build time) ───────────────

# Same Supabase project URL — used by the Supabase JS client in the browser
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable (anon) key — safe to expose in browser
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx
